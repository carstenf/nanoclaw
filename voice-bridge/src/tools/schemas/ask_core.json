{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ask_core",
  "type": "object",
  "additionalProperties": false,
  "required": ["topic", "request"],
  "properties": {
    "topic": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "maxLength": 64
    },
    "request": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    }
  }
}
