<!-- OpenAI SIP Profile — TLS signaling, SRTP media, outbound-only.
     Source: derived from freeswitch-config/conf/sip_profiles/openai.xml (H1 reference);
     Deploy context: voice-stack Phase 1 (2026-04-16, Option B after Option A insufficient).
     Port 5062 relies on Hetzner FW to block public ingress; sip-ip=0.0.0.0 so FS can
     select a routable source interface for outbound TLS to OpenAI (loopback bind
     breaks outbound routing — confirmed via `tport_tls_connect Invalid argument`). -->
<profile name="openai">
  <settings>
    <param name="context" value="openai-in"/>
    <param name="dialplan" value="XML"/>

    <!-- Bind all interfaces: required so outbound TLS can source from a routable IP -->
    <param name="sip-ip" value="$${local_ip_v4}"/>
    <param name="sip-port" value="5062"/>

    <!-- TLS signaling to OpenAI SIP endpoint.
         tls-version must be a SINGLE value per mod_sofia (comma-lists break init);
         vars.xml default is "tlsv1,tlsv1.1,tlsv1.2" (whole set) but we pin tlsv1.2
         per H1 reference to match OpenAI's advertised range (TLS 1.3 handshake
         verified via `openssl s_client` earlier, but comma-syntax in profile
         triggers SSL-uninitialized state). -->
    <param name="tls" value="true"/>
    <param name="tls-bind-params" value="transport=tls"/>
    <param name="tls-sip-port" value="5062"/>
    <param name="tls-version" value="tlsv1.2"/>

    <!-- RTP: media leaves the container on the public IP toward OpenAI Azure endpoint -->
    <param name="rtp-ip" value="128.140.104.236"/>

    <!-- SRTP mandatory for OpenAI (AEAD_AES_256_GCM_8 primary) -->
    <param name="rtp-secure-media" value="true"/>
    <param name="rtp-secure-media-suites" value="AEAD_AES_256_GCM_8,AEAD_AES_128_GCM_8,AES_CM_256_HMAC_SHA1_80,AES_CM_128_HMAC_SHA1_80"/>

    <!-- Codec: G.711 a-law for OpenAI leg (PCMU stays on Sipgate leg) -->
    <param name="inbound-codec-string" value="PCMA"/>
    <param name="outbound-codec-string" value="PCMA"/>

    <!-- Misc -->
    <param name="manage-presence" value="false"/>
    <param name="auth-calls" value="false"/>
  </settings>
</profile>
