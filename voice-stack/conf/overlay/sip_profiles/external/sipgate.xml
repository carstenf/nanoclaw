<include>
  <gateway name="sipgate">
    <param name="username" value="$${sipgate_username}"/>
    <param name="realm" value="$${sipgate_realm}"/>
    <param name="from-domain" value="$${sipgate_realm}"/>
    <param name="password" value="$${sipgate_password}"/>
    <param name="proxy" value="$${sipgate_realm}"/>
    <param name="register-proxy" value="$${sipgate_realm}"/>
    <param name="expire-seconds" value="300"/>
    <param name="register" value="true"/>
    <param name="retry-seconds" value="30"/>
    <param name="caller-id-in-from" value="true"/>
    <param name="context" value="public"/>
    <param name="ping" value="60"/>
  </gateway>
</include>
