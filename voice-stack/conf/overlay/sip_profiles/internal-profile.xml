<profile name="internal">
  <!-- Loopback-only profile. Used by the dialplan to bridge into sip-to-ai
       via 127.0.0.1:5080 so that both SIP signaling and RTP stay on lo and
       the source/destination IPs on both sides agree on 127.0.0.1. The
       external profile stays exclusively for Sipgate on the public IP. -->
  <domains>
    <domain name="all" alias="false" parse="false"/>
  </domains>
  <settings>
    <param name="debug" value="0"/>
    <param name="sip-trace" value="no"/>
    <param name="sip-port" value="5070"/>
    <param name="dialplan" value="XML"/>
    <param name="context" value="public"/>
    <param name="rfc2833-pt" value="101"/>
    <param name="dtmf-duration" value="2000"/>
    <param name="codec-prefs" value="PCMU"/>
    <param name="inbound-codec-prefs" value="PCMU"/>
    <param name="outbound-codec-prefs" value="PCMU"/>
    <param name="inbound-codec-negotiation" value="generous"/>
    <param name="rtp-timer-name" value="soft"/>
    <param name="rtp-ip" value="127.0.0.1"/>
    <param name="sip-ip" value="127.0.0.1"/>
    <param name="ext-rtp-ip" value="127.0.0.1"/>
    <param name="ext-sip-ip" value="127.0.0.1"/>
    <param name="auth-calls" value="false"/>
    <param name="manage-presence" value="false"/>
    <param name="hold-music" value="silence_stream://-1"/>
    <param name="auto-rtp-bugs" value="clear"/>
    <param name="NDLB-force-rport" value="safe"/>
  </settings>
</profile>
