<include>
  <!-- Inbound from Sipgate: answer and park for ESL control -->
  <extension name="sipgate-inbound">
    <condition field="destination_number" expression="^park$">
      <action application="set" data="hangup_after_bridge=true"/>
      <action application="answer"/>
      <action application="park"/>
    </condition>
  </extension>

  <!-- Bridge to OpenAI (triggered by ESL uuid_transfer) -->
  <extension name="openai-bridge">
    <condition field="destination_number" expression="^openai$">
      <action application="set" data="hangup_after_bridge=true"/>
      <action application="set" data="suppress_cng=true"/>
      <action application="set" data="bridge_generate_comfort_noise=false"/>
      <!-- PCMA + SRTP only on the OpenAI b-leg; Sipgate a-leg keeps G.722 -->
      <action application="bridge" data="{rtp_secure_media=true,absolute_codec_string=PCMA}sofia/external/sip:${openai_project_id}@sip.api.openai.com;transport=tls"/>
    </condition>
  </extension>
</include>
